<!DOCTYPE html>
<html>
<head>
  <title>License Dashboard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<h2>License Dashboard</h2>

<form method="POST" action="/admin/generate">
  <button type="submit">Generate License</button>
</form>

<table>
<tr>
  <th>Key</th>
  <th>Device</th>
  <th>Status</th>
  <th>Action</th>
</tr>

<% licenses.forEach(l => { %>
<tr>
  <td><%= l.license_key %></td>
  <td><%= l.device_id || '-' %></td>
  <td><%= l.status %></td>
  <td>
    <form method="POST" action="/admin/reset/<%= l.license_key %>" style="display:inline;">
      <button>Reset Device</button>
    </form>
    <% if (l.status === 'active') { %>
      <form method="POST" action="/admin/disable/<%= l.license_key %>" style="display:inline;">
        <button>Disable</button>
      </form>
    <% } else { %>
      <form method="POST" action="/admin/enable/<%= l.license_key %>" style="display:inline;">
        <button>Enable</button>
      </form>
    <% } %>
    <form method="POST" action="/admin/delete/<%= l.license_key %>" style="display:inline;">
      <button onclick="return confirm('Yakin?')">Delete</button>
    </form>
  </td>
</tr>
<% }) %>

</table>

<a href="/logout">Logout</a>

</body>
</html>